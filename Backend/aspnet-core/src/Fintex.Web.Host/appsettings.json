{
  "ConnectionStrings": {
    "Default": "__SET_VIA_ConnectionStrings__Default__"
  },
  "App": {
    "SelfUrl": "https://fintex.azurewebsites.net",
    "ServerRootAddress": "https://localhost:44311/",
    "ClientRootAddress": "http://localhost:4200/",
    "CorsOrigins": "http://localhost:4200,http://localhost:8080,http://localhost:8081,http://localhost:3000"
  },
  "Authentication": {
    "JwtBearer": {
      "IsEnabled": "true",
      "SecurityKey": "__SET_VIA_Authentication__JwtBearer__SecurityKey__",
      "Issuer": "Fintex",
      "Audience": "Fintex"
    }
  },
  "MarketData": {
    "Binance": {
      "Enabled": true,
      "StreamUrl": "wss://stream.binance.com:9443/stream?streams=",
      "Symbols": "btcusdt"
    },
    "Coinbase": {
      "Enabled": false,
      "StreamUrl": "wss://ws-feed.exchange.coinbase.com",
      "ProductIds": ""
    },
    "Oanda": {
      "Enabled": false,
      "PricingStreamUrl": "https://stream-fxpractice.oanda.com/v3",
      "AccountId": "",
      "ApiToken": "",
      "Instruments": ""
    }
  },
  "OpenAI": {
    "Endpoint": "https://api.openai.com/v1/responses",
    "Model": "gpt-4.1-mini",
    "ApiKey": "__SET_VIA_OpenAI__ApiKey__"
  },
  "News": {
    "RefreshWindowMinutes": 30,
    "Sources": {
      "CoinDesk": {
        "FeedUrl": "https://www.coindesk.com/arc/outboundfeeds/rss/"
      },
      "FederalReserve": {
        "FeedUrl": "https://www.federalreserve.gov/feeds/press_monetary.xml"
      },
      "Bls": {
        "FeedUrl": "https://www.bls.gov/feed/bls_latest.rss"
      },
      "Cftc": {
        "FeedUrl": "https://www.cftc.gov/RSS/PressReleases.xml"
      }
    }
  },
  "Notifications": {
    "Email": {
      "Enabled": true,
      "Host": "smtp.zeptomail.com",
      "Port": 587,
      "Username": "__SET_VIA_Notifications__Email__Username__",
      "Password": "__SET_VIA_Notifications__Email__Password__",
      "FromName": "Fintex Alerts",
      "FromAddress": "noreply@unihub.co.za",
      "UseStartTls": true,
      "UseSsl": false
    }
  },
  "MetaTraderBridge": {
    "PythonExecutable": "python",
    "ScriptPath": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "None"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "https://localhost:44311/"
      }
    }
  },
  "Swagger": {
    "ShowSummaries": false
  }
}
